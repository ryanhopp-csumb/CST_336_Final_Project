<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("partials/head.ejs") %>
</head>
<body>
    <%- include("partials/nav.ejs") %>

    <main class="cart-page">
        <h1>Shopping Cart</h1>

        <%
        let total = 0;
        if (cart && cart.length > 0) {
            cart.forEach(item => {
                total += item.price * (item.quantity || 1);
            });
        }
        %>

        <% if (!cart || cart.length === 0) { %>
            <div class="empty-cart">
                <div class="empty-cart-icon">Cart</div>
                <h2>Your cart is empty</h2>
                <p>Add some books to your cart to get started.</p>
                <a href="/" class="primary-btn">Browse Books</a>
            </div>
        <% } else { %>
            <div class="cart-container">
                <div class="cart-items">
                    <% cart.forEach(item => { %>
                        <div class="cart-item">
                            <div class="cart-book-image">
                                <% if (item.image) { %>
                                    <img src="<%= item.image %>" alt="<%= item.title %> cover">
                                <% } else { %>
                                    <div class="image-placeholder">No Cover</div>
                                <% } %>
                            </div>

                            <div class="cart-book-details">
                                <h2><%= item.title %></h2>
                                <p><%= item.author %></p>
                                <p>Price: $<%= item.price.toFixed(2) %></p>
                                <p>Quantity: <%= item.quantity || 1 %></p>

                                <form action="/cart/remove" method="POST">
                                    <input type="hidden" name="title" value="<%= item.title %>">
                                    <button type="submit" class="remove-btn">Remove</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="cart-summary">
                    <h2>Order Summary</h2>
                    <p>Subtotal: $<%= total.toFixed(2) %></p>
                    <p>Total: $<%= total.toFixed(2) %></p>
                    <a href="/pay" class="primary-btn">Checkout</a>
                </div>
            </div>
        <% } %>
    </main>
</body>
</html>