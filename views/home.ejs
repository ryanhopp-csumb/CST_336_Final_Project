<!DOCTYPE html>
<html lang="en">

<head>
    <%-include("partials/head.ejs")%>
</head>

<body>
    <%- include("partials/nav.ejs") %>
        <div class="browsing">
            <br>
            <h1> Discover Your Next Great Read<% if (user_Name) { %>, <%= user_Name %>!<% } else { %>!<% } %></h1>
            <div class="search-bar">
                <form action="/searchResults" method = "GET">
                    <input type="text" name= "searchTitle" id="searchInput" placeholder="Search by title or author...">
                    <button type = "submit" id="searchBtn">Search</button>
                </form>
            </div>

            <br>
            <br>
            <br>
            <ul id="bookList">
                <% for (let i of homeData) {%>
                    <li class="bookElement">
                        <img class="bookImage" width="150" src="<%=i.volumeInfo.imageLinks.smallThumbnail%>">
                        <div class="bookRow">
                            <h2 class="bookName">
                                <%=i.volumeInfo.title%><br>
                                    <%=i.volumeInfo.subtitle%>
                            </h2>
                            <h2 class="authorName">By <%=i.volumeInfo.authors%>
                            </h2>
                            <button class="showBookInfo" data-target="<%=i.id%>">Show More Info</button>
                        </div>
                        <dialog class="bookModal" id="<%=i.id%>">
                            <div class="bookInfo">
                                <button class="closeModal" data-target="<%=i.id%>">Close</button>
                                <form action="/addedToCart" method="POST">
                                    <button class="addToCart">Add Book to Cart</button>
                                </form>
                                <h2 class="authorName">
                                    <%=i.volumeInfo.authors%>
                                </h2>
                                <h2 class="bookName">
                                    <%=i.volumeInfo.title%><br>
                                    <%=i.volumeInfo.subtitle%>
                                </h2>
                                <img class="bookImage" width="250" src="<%=i.volumeInfo.imageLinks.thumbnail%>">
                                <h3 class="bookSummary">
                                    <%=i.volumeInfo.description%>
                                </h3>
                            </div>
                        </dialog>
                    </li>
                    <br>
                <%}%>
            </ul>
        </div>
<%- include("partials/footer.ejs") %>
</body>

</html>