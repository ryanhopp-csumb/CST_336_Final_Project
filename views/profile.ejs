<!DOCTYPE html>
<html>

<head>
    <title>Profile</title>
    <%- include("partials/head.ejs") %>
        <style>
            .profile-wrapper {
                width: 90%;
                max-width: 600px;
                margin: 40px auto;
            }

            .profile-card {
                background-color: rgb(83, 184, 204);
                padding: 3ch;
                border-radius: 15px;
            }

            .profile-field {
                margin-bottom: 18px;
            }

            .profile-field label {
                display: block;
                font-weight: bold;
                margin-bottom: 6px;
            }

            .profile-field input {
                width: 100%;
                padding: 10px 15px;
                border: 1px solid #ccc;
                border-radius: 8px;
                box-sizing: border-box;
            }

            .profile-field input:focus {
                outline: none;
                border-color: #2c7a7a;
            }

            .profile-btn {
                margin-top: 10px;
                background-color: antiquewhite;
                padding: 10px 24px;
                border-radius: 8px;
                cursor: pointer;
            }

            .profile-btn:hover {
                background-color: rgb(83, 184, 204);
            }

            .profile-alert {
                background-color: #d4edda;
                border: 1px solid #7cc47c;
                border-radius: 8px;
                padding: 10px 15px;
                margin-bottom: 18px;
                color: #1a4a1a;
            }
        </style>
</head>

<body>
    <%- include("partials/nav.ejs") %>

        <div class="profile-wrapper">
            <h1>Hi, <%= user.user_Name %>!</h1>

            <div class="profile-card">

                <% if (message) { %>
                    <div class="profile-alert">
                        <%= message %>
                    </div>
                    <% } %>

                        <form action="/profile/update" method="POST">

                            <div class="profile-field">
                                <label>First Name</label>
                                <input type="text" name="first_Name" value="<%= user.first_Name %>" required>
                            </div>

                            <div class="profile-field">
                                <label>Last Name</label>
                                <input type="text" name="Last_Name" value="<%= user.Last_Name %>" required>
                            </div>

                            <div class="profile-field">
                                <label>Username</label>
                                <input type="text" name="user_Name" value="<%= user.user_Name %>" required>
                            </div>

                            <div class="profile-field">
                                <label>Email</label>
                                <input type="email" name="email" value="<%= user.email %>" required>
                            </div>

                            <button type="submit" class="profile-btn">Save Changes</button>

                        </form>
            </div>
        </div>

</body>

</html>